[configuration]

entry_symbol = "korsim_engine_init"
compatibility_minimum = "4.1"
reloadable = true

[libraries]

linux.debug.x86_64 = "./libkorsim_engine.linux.template_debug.x86_64.so"
linux.release.x86_64 = "./libkorsim_engine.linux.template_release.x86_64.so"
linux.debug.arm64 = "./libkorsim_engine.linux.template_debug.arm64.so"
linux.release.arm64 = "./libkorsim_engine.linux.template_release.arm64.so"
